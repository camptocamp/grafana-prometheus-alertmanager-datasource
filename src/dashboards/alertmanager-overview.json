            "lineInterpolation": "linear",
            "lineWidth": 0,
            "pointSize": 9,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "always",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
